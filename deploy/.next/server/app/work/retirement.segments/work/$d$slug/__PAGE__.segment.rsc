d:["$","div",null,{"className":"my-4","children":["Using licensed imagery, the established color system (background & gradients), as well as the brand's inverted logo mark, this image can serve for banners, hero spots, covers (like the sponsorship brochure), & more!\n",["$","$La",null,{"src":"/work/retirement-academy/7.png","alt":"This image features several of the most critical assets the Retirement Academy uses in its branding, including: logo, typography, colors, & imagery.","caption":"This image features several of the most critical assets the Retirement Academy uses in its branding, including: logo, typography, colors, & imagery.","zoom":true}]]}]
