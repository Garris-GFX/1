8:["$","div",null,{"className":"my-4","children":["After drawing up several different portable building designs, we landed on this three-point perspective version, and the client was satisfied. We chose a popular, easy-to-read typography for their logo mark.\n",["$","$Ld",null,{"src":"/work/carolina-portable-buildings/1.png","alt":"Above is a snazzy mock-up depicting the logo on an app icon grid. The logo itself depicts a stylized version of a building or outhouse.","caption":"Above is a snazzy mock-up depicting the logo on an app icon grid. The logo itself depicts a stylized version of a building or outhouse.","zoom":true}]]}]
