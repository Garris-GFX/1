18:["$","div",null,{"className":"my-4","children":["I expanded on the icon design and gave it its own spotlight to showcase the custom brand background assets and color gradients.\n",["$","$L16",null,{"src":"/work/connect-social/6.png","alt":"This image depicts the brand's logo used in an application on a cell phone. It features another version of the color burst design asset discussed above.","caption":"This image depicts the brand's logo used in an application on a cell phone. It features another version of the color burst design asset discussed above.","zoom":true}]]}]
19:["$","h2",null,{"children":"Business Card Design"}]
1a:["$","div",null,{"className":"my-4","children":["What would a good concept project be without your standard \"What would it look like on a business card?\" test? In this picture you will find just one way to showcase the brand logo and business information in an eye-catching, colorful two-sided business card.\n",["$","$L16",null,{"src":"/work/connect-social/7.png","alt":"Two possible business card designs using the brand's logo and signature gradient set. These would really capture attention at events.","caption":"Two possible business card designs using the brand's logo and signature gradient set. These would really capture attention at events.","zoom":true}]]}]
1b:["$","h2",null,{"children":"The Solution"}]
1c:["$","p",null,{"children":"I developed a cohesive brand identity centered around a vibrant gradient color palette and modern typefaces to reflect the company’s values of innovation and connection. To reinforce the brand, I designed key materials, including sleek business cards, thank-you mailers for subscribers, and engaging social media post templates. This solution provides consistency and impact across all platforms, strengthening the company’s presence and client trust."}]
