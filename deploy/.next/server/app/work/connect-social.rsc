15:["$","aside",null,{"className":"self-start lg:sticky lg:top-24","children":["$","div",null,{"className":"bg-surface rounded-panel shadow-panel p-card space-y-card","children":[["$","$L1d",null,{"items":[{"level":2,"text":"The Problem"},{"level":2,"text":"Logo Inspiration"},{"level":2,"text":"Logo Construction"},{"level":2,"text":"Colors"},{"level":2,"text":"Social Media & Marketing Materials"},{"level":2,"text":"Brand Splash"},{"level":2,"text":"Icon Design: Application Usage"},{"level":2,"text":"Business Card Design"},{"level":2,"text":"The Solution"}],"inCard":false}],["$","hr",null,{"className":"w-full border-0 h-px bg-stroke"}],["$","div",null,{"className":"flex items-start gap-4","children":[["$","div",null,{"className":"relative h-12 w-12 shrink-0 overflow-hidden rounded-full bg-surface","children":["$","$L1e",null,{"src":"/profilepicture.JPG","alt":"Noah Hunt","fill":true,"className":"object-cover","sizes":"48px","priority":true}]}],["$","div",null,{"className":"min-w-0","children":[["$","a",null,{"href":"https://garris.graphics","className":"font-semibold text-white hover:underline","children":"Noah Hunt"}],["$","div",null,{"className":"text-sm text-muted","children":"Garris Graphics"}],["$","p",null,{"className":"mt-2 text-sm text-muted","children":"Branding + websites for small businesses that need a clean, fast, modern presence."}],["$","div",null,{"className":"mt-3","children":["$","$L12",null,{"href":"/contact","className":"text-sm font-medium text-text hover:text-white transition","children":"Work with me →"}]}]]}]]}]]}]}]
