b:["$","$La",null,{"src":"/work/flytrap/3.png","alt":"Scalable web design means building it to look great on all screen sizes. In this mock-up you can see Flytrap's web design in both cases.","caption":"Scalable web design means building it to look great on all screen sizes. In this mock-up you can see Flytrap's web design in both cases.","zoom":true}]
