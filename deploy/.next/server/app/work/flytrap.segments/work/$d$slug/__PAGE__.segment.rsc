d:["$","div",null,{"className":"my-4","children":["Custom shirts with a bold yellow print on deep green. These uniforms unify the crew and turn them into walking brand ambassadors. The oversized back print adds personality, while the chest logo keeps it subtle and professional from the front.\n",["$","$La",null,{"src":"/work/flytrap/2.png","alt":"Taking advantage of the cool artwork created for the expanded version of the Flytrap logo, I created this unique work shirt.","caption":"Taking advantage of the cool artwork created for the expanded version of the Flytrap logo, I created this unique work shirt.","zoom":true}]]}]
