5:[["$","p",null,{"children":"Welcome back! Below you will find all of the work I completed for Flytrap Properties LLC, as well as more information about design choices I made throughout the process. Thanks for taking a look! Scroll to explore."}],"\n",["$","h2",null,{"children":"The Problem"}],"\n",["$","div",null,{"className":"my-4","children":["Flytrap Properties, a Wilmington-based remodeling company, needed a bold, approachable identity that would separate it from traditional builders. The challenge was to bridge professionalism with playful personality—making remodeling and tiny home construction feel less intimidating and more exciting for homeowners.\n",["$","$La",null,{"src":"/work/flytrap/1.png","alt":"Hand-selected brand imagery and the brand's logo mark combine to produce this thumbnail. A light haze grounds the background in the brand's color system.","caption":"Hand-selected brand imagery and the brand's logo mark combine to produce this thumbnail. A light haze grounds the background in the brand's color system.","zoom":true}]]}],"\n",["$","h2",null,{"children":"Logo Variations"}],"\n",["$","div",null,{"className":"my-4","children":["Each version is tailored for use on signage, shirts, vehicles, or digital platforms—ensuring legibility and brand consistency across all formats.\n",["$","$La",null,{"src":"/work/flytrap/8.png","alt":"These logo variations represent all the different ways Flytrap Properties can present its logo. Arranged in a grid with call-outs makes explaining their usage even clearer.","caption":"These logo variations represent all the different ways Flytrap Properties can present its logo. Arranged in a grid with call-outs makes explaining their usage even clearer.","zoom":true}]]}],"\n",["$","h2",null,{"children":"Illustrated Brand Assets & Color System"}],"\n",["$","div",null,{"className":"my-4","children":["The illustrated mascot reinforces approachability and fun. The palette—ranging from mossy green to pinkish-red—grounds the brand in nature while providing contrast and vibrancy for print and digital use.\n",["$","$La",null,{"src":"/work/flytrap/6.png","alt":"In this image you will see some of the brand's assets rendered in a more detailed and colorful way. These could serve as stickers, T-shirt artwork, or anything else the brand needs a custom touch for.","caption":"In this image you will see some of the brand's assets rendered in a more detailed and colorful way. These could serve as stickers, T-shirt artwork, or anything else the brand needs a custom touch for.","zoom":true}]]}],"\n",["$","h2",null,{"children":"Blueprint Tube Mockup"}],"\n",["$","div",null,{"className":"my-4","children":["A branded architectural drawing featuring the Flytrap Properties logo. This emphasizes the company’s involvement in design-forward remodeling and planning—setting a tone of structure and precision while keeping branding top of mind, even in the details.\n",["$","$La",null,{"src":"/work/flytrap/4.png","alt":"In this mock-up you will find the Flytrap logo featured at the top of some build design plans. I included this to reinforce the brand's construction industry goals.","caption":"In this mock-up you will find the Flytrap logo featured at the top of some build design plans. I included this to reinforce the brand's construction industry goals.","zoom":true}]]}],"\n",["$","h2",null,{"children":"Responsive Website Design (Mobile & Desktop)"}],"\n",["$","div",null,{"className":"my-4","children":["A clean, mobile-first layout optimized for local clients. The olive tones reinforce the flytrap theme while strong call-to-actions encourage consultation booking. Designed to communicate trust, locality, and simplicity without overwhelming the user.\n","$Lb"]}],"\n","$Lc","\n","$Ld","\n","$Le","\n","$Lf","\n","$L10","\n","$L11"]
6:["$","div",null,{"className":"border-t border-stroke pt-card","children":["$","div",null,{"className":"grid gap-6 sm:grid-cols-2","children":[["$","$L4",null,{"href":"/work/flippers","className":"group","children":[["$","div",null,{"className":"text-xs font-semibold uppercase tracking-wide text-muted","children":"Previous project"}],["$","div",null,{"className":"mt-2 text-base font-semibold text-white group-hover:underline","children":"Concept: Flippers Snow Gear"}],["$","div",null,{"className":"mt-1 text-sm text-muted","children":"Brand design concept, brand mascot, and marketing materials for Flippers Snow Gear."}]]}],["$","$L4",null,{"href":"/work/watson","className":"group sm:text-right","children":[["$","div",null,{"className":"text-xs font-semibold uppercase tracking-wide text-muted","children":"Next project"}],["$","div",null,{"className":"mt-2 text-base font-semibold text-white group-hover:underline","children":"Branding: Watson Racing"}],["$","div",null,{"className":"mt-1 text-sm text-muted","children":"Logo, sponsorship proposal, and marketing materials for Watson Racing, Jacksonville, NC."}]]}]]}]}]
7:["$","aside",null,{"className":"self-start lg:sticky lg:top-24","children":["$","div",null,{"className":"bg-surface rounded-panel shadow-panel p-card space-y-card","children":[["$","$L12",null,{"items":[{"level":2,"text":"The Problem"},{"level":2,"text":"Logo Variations"},{"level":2,"text":"Illustrated Brand Assets & Color System"},{"level":2,"text":"Blueprint Tube Mockup"},{"level":2,"text":"Responsive Website Design (Mobile & Desktop)"},{"level":2,"text":"Branded Crew Shirts (Front & Back)"},{"level":2,"text":"Business Card Design"},{"level":2,"text":"The Solution"}],"inCard":false}],["$","hr",null,{"className":"w-full border-0 h-px bg-stroke"}],["$","div",null,{"className":"flex items-start gap-4","children":[["$","div",null,{"className":"relative h-12 w-12 shrink-0 overflow-hidden rounded-full bg-surface","children":["$","$L13",null,{"src":"/profilepicture.JPG","alt":"Noah Hunt","fill":true,"className":"object-cover","sizes":"48px","priority":true}]}],["$","div",null,{"className":"min-w-0","children":[["$","a",null,{"href":"https://garris.graphics","className":"font-semibold text-white hover:underline","children":"Noah Hunt"}],["$","div",null,{"className":"text-sm text-muted","children":"Garris Graphics"}],["$","p",null,{"className":"mt-2 text-sm text-muted","children":"Branding + websites for small businesses that need a clean, fast, modern presence."}],["$","div",null,{"className":"mt-3","children":["$","$L4",null,{"href":"/contact","className":"text-sm font-medium text-text hover:text-white transition","children":"Work with me →"}]}]]}]]}]]}]}]
