15:["$","ul",null,{"children":[["$","li",null,{"children":"Keep Your Website & Transfer It — we will provide a free self‑transfer backup or export to help you move the website to a new hosting provider. You are responsible for provisioning new hosting and managing your domain."}],["$","li",null,{"children":"Let Your Website Expire — if you choose not to transfer, your website will be removed from our servers at the end of your billing period."}]]}]
