6:["$","div",null,{"className":"mx-auto w-full max-w-[1200px] px-6 md:px-12 py-section","children":["$","div",null,{"className":"grid gap-card lg:grid-cols-[380px_1fr] xl:grid-cols-[420px_1fr] lg:items-start","children":[["$","aside",null,{"className":"lg:sticky lg:top-24 space-y-tile self-start","children":[["$","nav",null,{"aria-label":"Breadcrumbs","className":"text-crumbs uppercase tracking-crumbs text-text/60","children":[["$","span","Home-0",{"children":[["$","$L10",null,{"href":"/","className":"hover:text-white","children":"Home"}],["$","span",null,{"className":"mx-2 text-text/40","children":"/"}]]}],["$","span","Legal-1",{"children":[["$","$L10",null,{"href":"#","className":"hover:text-white","children":"Legal"}],["$","span",null,{"className":"mx-2 text-text/40","children":"/"}]]}],["$","span","Acceptable Use Policy-2",{"children":[["$","span",null,{"className":"text-white","children":"Acceptable Use Policy"}],null]}]]}],["$","h1",null,{"className":"text-h1 tracking-tightish text-white","children":"Acceptable Use Policy"}],["$","div",null,{"className":"text-small text-muted","children":["Last updated: ","2026-01-26"]}],["$","p",null,{"className":"text-body text-muted","children":"Rules governing acceptable use of Garris Graphics LLC services and site."}],null]}],["$","section",null,{"className":"min-w-0","children":["$","div",null,{"className":"prose prose-lg prose-invert max-w-none","children":[["$","h2",null,{"children":"Acceptable Use Policy"}],["$","p",null,{"children":"This Acceptable Use Policy sets expectations for lawful and respectful use of our services and website."}],["$","h2",null,{"children":"Prohibited conduct"}],["$","p",null,{"children":"Users must not use the Service for illegal activity, harassment, distribution of malware, or to interfere with the Service or other customers. Examples of prohibited uses include (without limitation):"}],["$","ul",null,{"children":[["$","li",null,{"children":"Content that promotes or facilitates illegal activity, violence, harassment, hate, or discrimination."}],["$","li",null,{"children":"Content that contains private or confidential information (credit card numbers, social security numbers, non-public personal data) without authorization."}],["$","li",null,{"children":"Child sexual abuse material, child erotica, or any content that harms or endangers minors."}],["$","li",null,{"children":"Pornographic, sexually explicit, or obscene material where prohibited by law or our service terms."}],["$","li",null,{"children":"Content intended to enable hacking, intrusion, or unauthorized access to systems."}],["$","li",null,{"children":"Open HTTP proxies, Tor relay services, or any anonymizing/proxy services intended to conceal malicious activity."}],["$","li",null,{"children":"Phishing pages, credential harvesting, or other attempts to fraudulently obtain credentials or financial data."}],["$","li",null,{"children":"Distribution of malware, viruses, trojans, worms, ransomware, or any code meant to damage or impair systems."}],["$","li",null,{"children":"Sites that facilitate piracy, warez, or unlawful sharing of copyrighted material."}],["$","li",null,{"children":"Unsolicited bulk email (spam) and abusive mailing practices; see below for limits and definitions."}],["$","li",null,{"children":"Any content that infringes the rights of third parties (copyright, trademark, privacy, publicity)."}],["$","li",null,{"children":"Content that excessively consumes resources through abusive striping or duplicate services to avoid overage fees."}]]}],["$","h2",null,{"children":"Passwords and account security"}],["$","p",null,{"children":"You are solely responsible for maintaining the confidentiality and security of passwords and access credentials for accounts and services provided by Garris Graphics LLC. Any activity that occurs under your account is presumed to be authorized by you. Use strong, unique passwords and update them periodically."}],"$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22"]}]}]]}]}]
11:["$","p",null,{"children":"If we detect insecure or compromised credentials, weak password usage, or repeated failed login attempts, we may require you to change your password, temporarily suspend access, or take other measures to protect the service and other customers."}]
12:["$","h2",null,{"children":"Spam and email limits"}]
13:["$","p",null,{"children":"Unsolicited bulk email (SPAM) is prohibited. For operational stability, Garris Graphics may limit email sending rates from hosted accounts. Excessive or abusive sending that harms infrastructure or results in blacklisting may result in suspension of the account."}]
14:["$","h2",null,{"children":"Additional usage restrictions"}]
15:["$","p",null,{"children":"We may remove or disable access to content that violates this policy, without notice. Additional examples of activities that may result in suspension or termination include:"}]
16:["$","ul",null,{"children":[["$","li",null,{"children":"Operating services that constantly exceed resource limits or spawn excessive connections."}],["$","li",null,{"children":"Using multiple accounts or services to 'stripe' content and avoid resource limits."}],["$","li",null,{"children":"Using our systems to host content that is advertised via spam or otherwise abused."}],["$","li",null,{"children":"Operating anonymizing networks, proxying, or other services intended to conceal abusive behavior."}],["$","li",null,{"children":"Hosting large-scale file dumps, warez, or pirate sites."}]]}]
17:["$","h2",null,{"children":"Third-party software and provider terms"}]
18:["$","p",null,{"children":"Use of control panels (cPanel, Plesk) or other third-party management tools is subject to those providers' license terms. Hosting, SSL, and other infrastructure services may be provided by third parties (for example, Hostwinds). Your use of those services is subject to their respective terms and agreements."}]
19:["$","h2",null,{"children":"Enforcement"}]
1a:["$","p",null,{"children":"We reserve the right to suspend or terminate accounts, remove or disable content, and cooperate with law enforcement where appropriate. Repeated or serious violations may lead to permanent account closure without refund."}]
1b:["$","p",null,{"children":["To report abuse, security issues, or suspected policy violations, please email",["$","a",null,{"href":"mailto:noah@garris.graphics","children":"noah@garris.graphics"}]," with details and relevant URLs."]}]
1c:["$","h2",null,{"children":"Email usage and storage"}]
1d:["$","p",null,{"children":"If you use email services provided or administered by Garris GFX (for example, addresses at @garris.graphics), you must use those accounts responsibly. Prohibited uses include sending unsolicited bulk email (spam), phishing, distributing malware, and using the service to harvest credentials or personally identifiable information."}]
1e:["$","p",null,{"children":"We may impose reasonable sending limits or suspend accounts that cause infrastructure harm or result in IP blacklisting. Persistent abuse may lead to account suspension or termination."}]
1f:["$","h2",null,{"children":"Email storage policy"}]
20:["$","p",null,{"children":"Email storage quotas and retention limits vary by plan. Users are responsible for managing mailbox size; Garris GFX may delete mail in accordance with the service plan or after prolonged inactivity. Critical email retention requirements should be specified in the service agreement."}]
21:["$","h2",null,{"children":"Professional email providers"}]
22:["$","p",null,{"children":"If professional email services (Fastmail, Google Workspace, Microsoft 365, etc.) are used, administrative setup and ongoing management are described in the service agreement and are subject to those providers' terms of service and privacy policies."}]
