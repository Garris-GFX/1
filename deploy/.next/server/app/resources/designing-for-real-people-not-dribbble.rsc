on.",["$","br",null,{}],"\n","Readable text beats trendy text.",["$","br",null,{}],"\n","Predictable interactions beat surprising ones."]}],"\n"]}],"\n",["$","p",null,{"children":["This does not mean design should be dull.",["$","br",null,{}],"\n","It means beauty should come ",["$","em",null,{"children":"from usability"}],", not fight against it."]}],"\n",["$","hr",null,{}],"\n",["$","h2",null,{"children":"Dribbble is not the internet"}],"\n",["$","p",null,{"children":"Most Dribbble shots are:"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Static"}],"\n",["$","li",null,{"children":"Perfectly cropped"}],"\n",["$","li",null,{"children":"Context-free"}],"\n",["$","li",null,{"children":"Untested"}],"\n",["$","li",null,{"children":"Unconstrained by content"}],"\n"]}],"\n",["$","p",null,{"children":"They don’t show:"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Long headlines"}],"\n",["$","li",null,{"children":"Real copy"}],"\n",["$","li",null,{"children":"Error states"}],"\n",["$","li",null,{"children":"Accessibility requirements"}],"\n",["$","li",null,{"children":"Performance constraints"}],"\n",["$","li",null,{"children":"CMS limitations"}],"\n"]}],"\n",["$","p",null,{"children":["That doesn’t make them useless — but it makes them ",["$","strong",null,{"children":"incomplete"}],"."]}],"\n",["$","p",null,{"children":"A design that only works at one screen size, with perfect content, and zero edge cases is not finished design. It’s visual exploration."}],"\n",["$","hr",null,{}],"\n",["$","h2",null,{"children":"Real design starts with constraints"}],"\n",["$","p",null,{"children":"Constraints are not a limitation. They are the job."}],"\n",["$","p",null,{"children":"Good design answers questions like:"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"What happens when this headline is twice as long?"}],"\n",["$","li",null,{"children":"What does this look like on a cheap Android phone?"}],"\n",["$","li",null,{"children":"Can a first-time user understand this in 3 seconds?"}],"\n",["$","li",null,{"children":"What breaks if content is missing?"}],"\n",["$","li",null,{"children":"What happens when JavaScript fails?"}],"\n"]}],"\n",["$","p",null,{"children":"If your design cannot survive those questions, it is not ready."}],"\n","$L14","\n","$L15","\n","$L16","\n","$L17","\n","$L18","\n","$L19","\n","$L1a","\n","$L1b","\n","$L1c","\n","$L1d","\n","$L1e","\n","$L1f","\n","$L20","\n","$L21","\n","$L22","\n","$L23","\n","$L24","\n","$L25","\n","$L26","\n","$L27","\n","$L28","\n","$L29","\n","$L2a"]}],"$L2b"]}],"$L2c"]}]
