5:[["$","p",null,{"children":"When you design without real content you design a shell. Content-first design flips that: start with headings, real paragraphs, and the actual CTAs."}],"\n",["$","p",null,{"children":"Benefits:"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Fewer mid-project surprises when copy arrives."}],"\n",["$","li",null,{"children":"Better hierarchy and spacing decisions."}],"\n",["$","li",null,{"children":"More realistic performance and accessibility trade-offs."}],"\n"]}],"\n",["$","p",null,{"children":"Practical steps:"}],"\n",["$","ol",null,{"children":["\n",["$","li",null,{"children":"Wire a page using real headlines and 2–3 variations for each block."}],"\n",["$","li",null,{"children":"Test a long headline and a short one; adapt the grid to both."}],"\n",["$","li",null,{"children":"Review images and captions as part of the layout, not after."}],"\n"]}],"\n",["$","p",null,{"children":"Content-first doesn't oppose creative exploration — it channels it to real constraints so the final site actually works for users."}]]
