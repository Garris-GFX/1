5:[["$","p",null,{"children":"Small sites don't need complex instrumentation to feel fast. Focus on the largest wins that are simple to implement."}],"\n",["$","p",null,{"children":"Priority list:"}],"\n",["$","ol",null,{"children":["\n",["$","li",null,{"children":"Image sizing: serve appropriately sized images and use modern formats (AVIF/WebP where supported)."}],"\n",["$","li",null,{"children":"Critical CSS: inline minimal critical styles for above-the-fold content."}],"\n",["$","li",null,{"children":"Limit third-party scripts: each adds latency and potential layout shift."}],"\n",["$","li",null,{"children":"Defer nonessential JS and hydrate interactive parts only when necessary."}],"\n"]}],"\n",["$","p",null,{"children":["Tooling: Lighthouse for a quick audit; ",["$","code",null,{"children":"next/image"}]," or an image CDN to automate responsive images; ",["$","code",null,{"children":"prefetch"}],"/",["$","code",null,{"children":"preload"}]," for critical assets."]}],"\n",["$","p",null,{"children":"Measure before and after: pick a slow page, apply one change, and measure perceived speed improvements."}]]
