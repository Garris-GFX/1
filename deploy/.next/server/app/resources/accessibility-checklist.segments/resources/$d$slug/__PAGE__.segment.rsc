5:[["$","p",null,{"children":"Accessibility often feels big, but many important wins are quick and repeatable. Use this short checklist during reviews."}],"\n",["$","p",null,{"children":"Color & contrast"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Ensure text contrast >= 4.5:1 for body text and 3:1 for large headings."}],"\n",["$","li",null,{"children":"Avoid conveying meaning using color alone."}],"\n"]}],"\n",["$","p",null,{"children":"Structure & semantics"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Use headings in order (H1 → H2 → H3)."}],"\n",["$","li",null,{"children":"Provide meaningful alt text for images."}],"\n"]}],"\n",["$","p",null,{"children":"Keyboard & focus"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Ensure all interactive elements are reachable by keyboard."}],"\n",["$","li",null,{"children":"Visible focus indicators on links/buttons."}],"\n"]}],"\n",["$","p",null,{"children":"Forms & labels"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Associate labels with inputs; provide helpful error messages."}],"\n"]}],"\n",["$","p",null,{"children":"Performance & timing"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Avoid auto-playing media; allow users to pause/stop."}],"\n"]}],"\n",["$","p",null,{"children":"Run this list on every release — small checks become a habit that dramatically improves usability."}]]
