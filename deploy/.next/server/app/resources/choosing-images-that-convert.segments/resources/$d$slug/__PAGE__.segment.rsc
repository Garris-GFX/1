5:[["$","p",null,{"children":"Images are not decoration — they guide attention and build trust. Choose photos that support the message and reduce cognitive friction."}],"\n",["$","p",null,{"children":"Guidelines:"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Lead with context: show the product in use rather than isolated studio shots."}],"\n",["$","li",null,{"children":"Faces + gaze: people looking toward a CTA or product increase attention toward it."}],"\n",["$","li",null,{"children":"Authenticity over perfection: real, slightly imperfect photos often feel more trustworthy."}],"\n",["$","li",null,{"children":"Optimize for devices: crop and serve images appropriate for small screens."}],"\n"]}],"\n",["$","p",null,{"children":"Testing: try A/B testing hero images for click-through and measure time-on-page. Small swaps can deliver meaningful lift."}]]
