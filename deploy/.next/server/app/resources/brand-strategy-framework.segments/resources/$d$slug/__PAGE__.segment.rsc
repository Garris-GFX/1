5:[["$","p",null,{"children":"Brand strategy doesn't need to be long to be useful. The goal is clarity: what you stand for, who you serve, and how you act differently."}],"\n",["$","p",null,{"children":"Start with three simple planes:"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Purpose: the core reason you exist beyond features and price."}],"\n",["$","li",null,{"children":"Promise: the primary benefit customers should expect."}],"\n",["$","li",null,{"children":"Personality: the consistent tone and visual vocabulary you use."}],"\n"]}],"\n",["$","p",null,{"children":"Use these planes to make everyday choices: button style, photography, copy tone, pricing page structure. If a decision doesn't support your purpose, question it."}],"\n",["$","p",null,{"children":"Apply the framework monthly: pick one plane and audit a page or touchpoint. Small, focused improvements compound into a reliable brand experience without a heavy retainer."}],"\n",["$","p",null,{"children":"Checklist"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Write a one-sentence purpose."}],"\n",["$","li",null,{"children":"Define a one-line promise."}],"\n",["$","li",null,{"children":"Pick three personality adjectives and enforce them across channels."}],"\n"]}],"\n",["$","p",null,{"children":"This lightweight approach keeps brand work practical and repeatable — exactly what small teams need."}]]
