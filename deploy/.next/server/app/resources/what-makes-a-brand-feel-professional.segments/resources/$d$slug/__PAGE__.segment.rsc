5:[["$","p",null,{"children":"Small design choices add up. Professional brands feel intentional because their pieces fit together."}],"\n",["$","p",null,{"children":"This article walks through the practical things that make a brand feel put-together and trustworthy."}],"\n",["$","h2",null,{"children":"Typography"}],"\n",["$","p",null,{"children":"Consistency in typography matters more than clever fonts. Use a small, well-scaled system and stick to it."}],"\n",["$","h2",null,{"children":"Spacing"}],"\n",["$","p",null,{"children":"Good spacing creates rhythm. It helps users parse groups of content quickly."}],"\n",["$","h2",null,{"children":"Photography"}],"\n",["$","p",null,{"children":"Use real photos when possible — stock shots often feel generic."}]]
